<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动浏览助手"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- APP选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择要浏览的APP"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerApp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:color/white"
            android:layout_marginBottom="20dp" />

        <!-- 浏览时长 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="浏览时长"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 分钟"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekBarDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- 滚动次数 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="滚动次数"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textScrollCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50 次"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekBarScrollCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- 随机延迟 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="随机延迟"
                android:textSize="16sp"
                android:textColor="#666666" />

            <Switch
                android:id="@+id/switchRandomDelay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 状态显示 -->
        <TextView
            android:id="@+id/textStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="等待开始"
            android:textSize="14sp"
            android:textColor="#999999"
            android:gravity="center"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- 操作按钮 -->
        <Button
            android:id="@+id/buttonStart"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="开始自动浏览"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_start"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/buttonStop"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="停止浏览"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_stop"
            android:enabled="false"
            android:layout_marginBottom="20dp" />

        <!-- 说明 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="说明：\n1. 首次使用需要开启无障碍服务\n2. 选择要自动浏览的APP\n3. 设置浏览时长和滚动次数\n4. 开启随机延迟可模拟真实用户行为"
            android:textSize="12sp"
            android:textColor="#999999"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</ScrollView>
